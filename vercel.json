{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/login",
            "destination": "/api/login.js"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/client/dist/$1"
        }
    ]
}